#
# ~/.bashrc
#
# Interactive Shell Configuration
#
# This is sourced by the login shell (bash_profile). Any intended difference
# in behavior between a Login and Interactive shell should be handled 
# appropriately here.
#
# Author: Michael Gilchrist (michaelgilch@gmail.com)

PS1='[\u@\h \W]\$ '

export EDITOR="vim"
export VISUAL="$EDITOR"
export MANPAGER="less --no-init"
export MANROFFOPT="-c"  # legacy groff output so LESS_TERMCAP colors apply
export PATH=$HOME/.npm-global/bin:$PATH
export PATH=$HOME/.local/bin:$PATH

export DOTFILES="$HOME/dotfiles"

# History
# note: ~/.bash_prompt has mechanism to append history after every prompt
HISTCONTROL=ignoredups:ignorespace
HISTSIZE=100000
HISTFILESIZE=$HISTSIZE
HISTIGNORE="clear:c:history:h:exit"
shopt -s histappend

# Additional Sources
[ -f "$HOME"/.bash_aliases ] && source "$HOME"/.bash_aliases
[ -f "$HOME"/.bash_functions ] && source "$HOME"/.bash_functions
[ -f "$HOME"/.bash_prompt ] && source "$HOME"/.bash_prompt
[ -f "$HOME"/.less_termcap ] && source "$HOME"/.less_termcap

# Secrets - not tracked in dotfiles
[ -f "$HOME"/.env.secrets ] && source "$HOME"/.env.secrets
