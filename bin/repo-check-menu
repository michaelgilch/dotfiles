#!/bin/bash
# jgmenu pipe script: list git repos that are out of sync.
# Reads the public report.json (written by `repo-check run`/`fetch`). Each
# entry opens a kitty terminal at that repo; the "Refresh repo" submenu
# fetches a single repo's remote data and reopens the popup, so an entry
# that is only stale (not really dirty) can be cleared without a full
# fetch. Called from repo-check-popup.

STATE="${REPO_CHECK_STATE:-$HOME/.local/state/repo-check}/report.json"

dirty=0
[[ -s "$STATE" ]] && dirty=$(jq -r '.summary.dirty' "$STATE")

if [[ "$dirty" -eq 0 ]]; then
    echo "^sep(Git repos)"
    echo "All repos in sync,:,object-select-symbolic"
    echo "^sep()"
    echo "Re-check now,kitty --hold repo-check run --all,view-refresh"
    exit 0
fi

echo "^sep(Out of sync)"
jq -r '.repos | sort_by(.name | ascii_downcase)[] | select(.dirty)
        | "\(.name)  [\(.short)],kitty --directory \"\(.path)\",folder"' "$STATE"

echo "^sep()"
echo "Refresh repo,^checkout(refresh),view-refresh"
echo "Full report,kitty --hold repo-check run --all,text-x-generic"
echo "Re-check (local),kitty --hold repo-check run,view-refresh"
echo "Fetch remotes (slow),kitty --hold repo-check fetch,network-transmit-receive"

# Submenu: fetch ONE repo's remote refs quietly, then reopen the popup so the
# refreshed (possibly now-clean) list is immediately visible.
echo "^tag(refresh)"
echo "^sep(Refresh remote data)"
jq -r '.repos | sort_by(.name | ascii_downcase)[] | select(.dirty)
        | "\(.name),sh -c '\''repo-check fetch \"\(.path)\" >/dev/null 2>&1; repo-check-popup'\'',network-transmit-receive"' "$STATE"
echo "^sep()"
echo "Back,^back(),go-previous"
