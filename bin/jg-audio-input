#!/bin/bash
# jgmenu pipe script for selecting the default audio input device
#
# Device registry: "Friendly Name|pactl_name_pattern|icon"
# Only devices matching a registry entry AND currently available are shown.
# Add new devices here as needed.

DEVICES=(
    "Shure MV7+|alsa_input.usb-Shure_Inc.*|audio-input-microphone"
    "Webcam|alsa_input.usb-Anker_PowerConf.*|camera-web"
    "Bluetooth|bluez_input.*|audio-headset"
)

current_default=$(pactl get-default-source)
# Exclude .monitor sources
available_sources=$(pactl list sources short | awk '{print $2}' | grep -v '\.monitor$')

for entry in "${DEVICES[@]}"; do
    IFS='|' read -r label pattern icon <<< "$entry"

    match=$(echo "$available_sources" | grep -m1 -E "$pattern")
    [[ -z "$match" ]] && continue

    prefix=""
    [[ "$match" == "$current_default" ]] && prefix="* "

    echo "${prefix}${label},pactl set-default-source ${match} && notify-send -h string:x-dunst-stack-tag:audio-switch 'Audio Input' 'Switched to ${label}',${icon}"
done
